PORT=3000
# From Google Cloud Console: APIs & Services > Credentials > OAuth 2.0 Client (Web application)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
# Must match exactly the "Authorized redirect URIs" in Google Console (e.g. http://localhost:3000/oauth/callback)
OAUTH_REDIRECT_URI=http://localhost:3000/oauth/callback
# 32-byte hex string for AES-256 (e.g. openssl rand -hex 32)
ENCRYPTION_KEY=your_32_byte_hex_key
# Allowed extension origin for CORS (e.g. chrome-extension://abcdefghijklmnop)
EXTENSION_ORIGIN=chrome-extension://your_extension_id
# Redirect after OAuth - must match extension (e.g. chrome-extension://id/success.html)
OAUTH_SUCCESS_REDIRECT=chrome-extension://your_extension_id/success.html
